# ============================================================
# ACCC — Environment Variables Template
# Copy this file to .env and fill in the required values.
#   cp .env.example .env
#
# Required fields are marked with [REQUIRED].
# All others have safe defaults and are optional.
# ============================================================


# ── AI ────────────────────────────────────────────────────────────────────────

# [REQUIRED] Your OpenAI API key — system refuses to start without this
OPENAI_API_KEY=your-key-here


# ── PostgreSQL ────────────────────────────────────────────────────────────────

# [REQUIRED] PostgreSQL password
POSTGRES_PASSWORD=accc_secret_password

# PostgreSQL username (default: accc)
POSTGRES_USER=accc

# PostgreSQL database name (default: accc_db)
POSTGRES_DB=accc_db


# ── Auth ──────────────────────────────────────────────────────────────────────

# [REQUIRED] JWT signing secret — generate with: openssl rand -hex 32
JWT_SECRET=change-me-generate-with-openssl-rand-hex-32


# ── Redis ─────────────────────────────────────────────────────────────────────

# Redis connection string (default works with Docker Compose)
REDIS_URL=redis://redis:6379


# ── ChromaDB ──────────────────────────────────────────────────────────────────

# ChromaDB hostname (default works with Docker Compose)
CHROMADB_HOST=chromadb

# ChromaDB port (default: 8000 inside Docker network)
CHROMADB_PORT=8000


# ── Threat Intelligence APIs ──────────────────────────────────────────────────

# AbuseIPDB API key (optional — free tier at https://www.abuseipdb.com)
# If absent: live IP reputation lookup is skipped; GeoIP still works.
ABUSEIPDB_API_KEY=your-abuseipdb-key-here


# ── Log Generator ─────────────────────────────────────────────────────────────

# Events per minute emitted by the mock log generator (default: 30)
LOG_GENERATOR_RATE=30


# ── Application Behaviour ─────────────────────────────────────────────────────

# Enable browser audio chimes for CRITICAL/HIGH events (default: true)
ENABLE_AUDIO_ALERTS=true

# Environment mode:
#   production  → CORS restricted to http://localhost:3000
#   development → CORS wildcard (*) + debug logging enabled
ENVIRONMENT=production

# Python logging level: DEBUG | INFO | WARNING | ERROR (default: INFO)
LOG_LEVEL=INFO
